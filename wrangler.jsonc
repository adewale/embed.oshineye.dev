{
  // embeds.oshineye.dev — Cloudflare Worker config
  "name": "embeds",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-13",
  "assets": {
    "directory": "public"
  },
  "rules": [
    { "type": "Text", "globs": ["**/*.html"] }
  ],
  "routes": [
    {
      "pattern": "embeds.oshineye.dev",
      "custom_domain": true
    }
  ]
}
